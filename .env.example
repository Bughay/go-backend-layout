
PORT=8080
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY_HOURS=24
SERVER_READ_TIMEOUT_SEC=10
SERVER_WRITE_TIMEOUT_SEC=30


DB_DRIVER=postgres
DB_USER=backend_developer
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=go_backend_layout
DB_SSLMODE=disable
DATABASE_URL="${DB_DRIVER}://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}"